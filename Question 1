\\find the radius, area and perimeter of a circle using symbolic constants

#include <stdio.h> 
#include <math.h> 
#define pi 3.14 

float x1,x2,y1,y2,diameter,radius; 
void radius(); 
void area(); 
void perimeter();
int main()
{ 
  printf("Enter the coordinates:"); 
  scanf("%f %f %f %f",&x1,&y1,&x2,&y2);
  radius(); 
  area(); 
  perimeter(); 
  return 0;
}
void radius() 
{ 
  diameter=sqrt(pow(x2-x1,2)+pow(y2-y1,2)); 
  radius=diameter/2; 
  printf("\nDiameter of circle is %f", diameter);  
  printf("\nRadius of circle is %f",radius); 
  printf("\nRadius of circle after typecasting is %d",(int)radius); 
} 
void area() 
{  
  float area=pi*pow(radius,2); 
  printf("\nArea of circle is %f",area); 
}  
  void perimeter() 
{
  int perimeter; 
  float perimeter=2*pi*radius; 
  printf("\nPerimeter of circle is %f",perimeter);   
}
